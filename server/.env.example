# Django Configuration
DJANGO_SETTINGS_MODULE=config.settings.development
DEBUG=True
SECRET_KEY=replace-with-a-long-random-secret-key-at-least-50-characters
JWT_SIGNING_KEY=your-jwt-signing-key-here-generate-a-new-one-at-least-64-bytes-for-hs512

# MariaDB Configuration
DB_NAME=booknest_db
DB_USER=booknest
DB_PASSWORD=your_secure_password_here
DB_HOST=db
DB_PORT=3306
MARIADB_ROOT_PASSWORD=your_secure_root_password_here

# Cloudinary Configuration (for media storage)
CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret

# Redis Configuration (optional)
REDIS_URL=redis://redis:6379/1
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/0
CELERY_ACCEPT_CONTENT=json
CELERY_TASK_SERIALIZER=json
CELERY_RESULT_SERIALIZER=json
CELERY_TIMEZONE=UTC


# Security Settings (for production)
ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0
CSRF_TRUSTED_ORIGINS=http://localhost:8000,http://127.0.0.1:8000
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:5173,http://127.0.0.1:5173
SECURE_SSL_REDIRECT=True
SECURE_HSTS_SECONDS=31536000
SECURE_HSTS_INCLUDE_SUBDOMAINS=True
SECURE_HSTS_PRELOAD=True

# Email and app URLs
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
DEFAULT_FROM_EMAIL=
FRONTEND_URL=http://localhost:3000
SITE_NAME=BookNest

# Logging
DJANGO_LOG_DIR=logs
DJANGO_LOG_FILE=logs/django_debug.log
RECOMMENDATION_LOG_FILE=logs/recommendation.log

# Seed data
SEED_ADMIN_USERNAME=admin
SEED_ADMIN_EMAIL=admin@booknest.local
SEED_ADMIN_PASSWORD=change-me-admin-password
SEED_USER_PASSWORD=change-me-demo-user-password
